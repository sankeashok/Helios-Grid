# Azure Configuration
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=mlops-rg
AZURE_ML_WORKSPACE=mlops-workspace
AZURE_LOCATION=eastus2

# Azure Storage
AZURE_STORAGE_ACCOUNT=mlopsstorage
AZURE_CONTAINER_NAME=datasets

# Azure Key Vault
AZURE_KEYVAULT_NAME=mlops-keyvault

# Kaggle API
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# MLflow Tracking
MLFLOW_TRACKING_URI=azureml://eastus2.api.azureml.ms
MLFLOW_EXPERIMENT_NAME=house-price-prediction

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Model Configuration
MODEL_NAME=house-price-model
MODEL_VERSION=latest
DRIFT_THRESHOLD=0.1

# Monitoring
ENABLE_MONITORING=true
LOG_LEVEL=INFO