[flake8]
max-line-length = 88
extend-ignore = E203,W503,F401,F841,E501,W291,W293,E722,F541,E402,E301,E302,F811
exclude = 
    helios-grid-env,
    .git,
    __pycache__,
    .pytest_cache,
    node_modules,
    react-frontend/node_modules,
    .venv,
    venv,
    build,
    dist,
    *.egg-info
per-file-ignores =
    __init__.py:F401
    tests/*:F401,F841
    scripts/*:F401,F841